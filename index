<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sistema Cómputo</title>
<script src="https://cdn.jsdelivr.net/npm/firebase@10.12.2/firebase-app-compat.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/firebase@10.12.2/firebase-firestore-compat.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', system-ui, sans-serif; background: #f0f2f5; display: flex; min-height: 100vh; color: #1e293b; }

  /* Sidebar */
  .sidebar { width: 230px; background: #1a1f2e; color: white; height: 100vh; padding: 20px 0; position: sticky; top: 0; flex-shrink: 0; overflow-y: auto; }
  .sidebar-logo { padding: 0 16px 6px; font-size: 13px; font-weight: 700; color: #fff; letter-spacing: .02em; }
  .sidebar-sub { padding: 0 16px 18px; font-size: 11px; color: rgba(255,255,255,0.35); border-bottom: 1px solid rgba(255,255,255,0.08); margin-bottom: 10px; }
  .sidebar nav button { width: 100%; background: none; border: none; border-left: 2px solid transparent; color: rgba(255,255,255,0.6); padding: 10px 16px; text-align: left; cursor: pointer; font-size: 13px; transition: all .15s; display: flex; align-items: center; gap: 8px; }
  .sidebar nav button:hover { color: #fff; background: rgba(255,255,255,0.06); }
  .sidebar nav button.active { color: #fff; border-left-color: #6366f1; background: rgba(99,102,241,0.15); }
  .nav-icon { font-size: 15px; flex-shrink: 0; }
  .sidebar-badge { display: inline-flex; align-items: center; justify-content: center; background: #dc2626; color: white; font-size: 10px; font-weight: 700; border-radius: 20px; padding: 1px 6px; margin-left: auto; min-width: 18px; }

  /* Layout */
  .main { flex: 1; padding: 24px; overflow: auto; }
  .section { display: none; }
  .section.visible { display: block; }
  .page-header { margin-bottom: 20px; display: flex; align-items: center; justify-content: space-between; }
  .page-header h2 { font-size: 18px; font-weight: 600; }
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .three-col { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }

  /* Metrics */
  .metrics-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 12px; margin-bottom: 20px; }
  .metric { background: white; border-radius: 10px; padding: 16px; border: 0.5px solid rgba(0,0,0,0.07); }
  .metric-label { font-size: 12px; color: #64748b; margin-bottom: 4px; }
  .metric-value { font-size: 28px; font-weight: 600; color: #1e293b; }
  .metric-value.ok   { color: #16a34a; }
  .metric-value.fail { color: #dc2626; }
  .metric-value.warn { color: #d97706; }
  .metric-value.info { color: #6366f1; }
  .metric-sub { font-size: 11px; color: #94a3b8; margin-top: 3px; }

  /* Cards */
  .card { background: white; border-radius: 12px; padding: 20px; border: 0.5px solid rgba(0,0,0,0.07); margin-bottom: 16px; }
  .card-title { font-size: 14px; font-weight: 600; margin-bottom: 16px; color: #1e293b; display: flex; align-items: center; gap: 8px; }

  /* Badges */
  .badge { display: inline-flex; align-items: center; gap: 5px; padding: 3px 10px; border-radius: 6px; font-size: 12px; font-weight: 500; }
  .badge-ok     { background: #dcfce7; color: #166534; }
  .badge-warn   { background: #fef9c3; color: #854d0e; }
  .badge-danger { background: #fee2e2; color: #991b1b; }
  .badge-info   { background: #ede9fe; color: #5b21b6; }

  /* Estado chips */
  .chip { display: inline-block; padding: 2px 9px; border-radius: 20px; font-size: 11px; font-weight: 600; }
  .chip-activo   { background: #dcfce7; color: #166534; }
  .chip-falla    { background: #fee2e2; color: #991b1b; }
  .chip-mant     { background: #fef9c3; color: #854d0e; }
  .chip-baja     { background: #f1f5f9; color: #64748b; }
  .chip-laptop   { background: #ede9fe; color: #5b21b6; }
  .chip-desktop  { background: #dbeafe; color: #1d4ed8; }

  /* Forms */
  .form-section { margin-bottom: 18px; }
  .form-section-title { font-size: 12px; font-weight: 600; color: #6366f1; text-transform: uppercase; letter-spacing: .06em; margin-bottom: 10px; padding-bottom: 6px; border-bottom: 1px solid #e2e8f0; }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 4px; }
  .form-grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin-bottom: 4px; }
  .form-group { display: flex; flex-direction: column; gap: 4px; }
  .form-group label { font-size: 12px; color: #64748b; font-weight: 500; }
  .form-group input, .form-group select, .form-group textarea {
    width: 100%; padding: 7px 10px; border-radius: 6px; border: 1px solid #e2e8f0;
    font-size: 13px; color: #1e293b; background: white; outline: none; transition: border-color .15s; font-family: inherit;
  }
  .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: #6366f1; }
  .form-group textarea { resize: vertical; min-height: 60px; }
  .span2 { grid-column: span 2; }
  .span3 { grid-column: span 3; }

  /* Buttons */
  .btn { padding: 7px 16px; border: none; border-radius: 6px; cursor: pointer; font-size: 13px; font-weight: 500; transition: all .15s; }
  .btn:hover { opacity: .85; }
  .btn-primary { background: #6366f1; color: white; }
  .btn-danger  { background: #dc2626; color: white; }
  .btn-success { background: #16a34a; color: white; }
  .btn-amber   { background: #d97706; color: white; }
  .btn-gray    { background: #f1f5f9; color: #64748b; border: 1px solid #e2e8f0; }
  .btn-outline { background: white; color: #6366f1; border: 1px solid #6366f1; }
  .btn-sm { padding: 4px 10px; font-size: 12px; }
  .btn-bar { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; margin-top: 12px; }

  /* Tables */
  .table-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  thead tr { border-bottom: 2px solid #e2e8f0; background: #f8fafc; }
  th { padding: 9px 10px; text-align: left; font-size: 11px; color: #64748b; font-weight: 600; text-transform: uppercase; letter-spacing: .04em; }
  td { padding: 10px 10px; border-bottom: 1px solid #f1f5f9; color: #334155; vertical-align: middle; }
  tr:hover td { background: #fafafa; }
  tr:last-child td { border-bottom: none; }

  /* Filter bar */
  .filter-bar { display: flex; gap: 10px; align-items: center; margin-bottom: 16px; flex-wrap: wrap; }
  .filter-bar select, .filter-bar input { padding: 7px 10px; border-radius: 6px; border: 1px solid #e2e8f0; font-size: 13px; outline: none; color: #1e293b; }
  .filter-bar select:focus, .filter-bar input:focus { border-color: #6366f1; }

  /* Empty */
  .empty { text-align: center; padding: 40px; color: #94a3b8; font-size: 13px; }
  .empty .e-icon { font-size: 32px; margin-bottom: 10px; }

  /* Toast */
  #toast { position: fixed; bottom: 24px; right: 24px; background: #1e293b; color: white; padding: 10px 18px; border-radius: 8px; font-size: 13px; opacity: 0; transition: opacity .3s; pointer-events: none; z-index: 9999; }
  #toast.show { opacity: 1; }

  /* Branch bars */
  .branch-list { display: flex; flex-direction: column; gap: 10px; }
  .branch-row { display: flex; align-items: center; gap: 10px; font-size: 13px; }
  .branch-name { width: 120px; color: #64748b; flex-shrink: 0; font-size: 12px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .bar-track { flex: 1; height: 8px; background: #f1f5f9; border-radius: 4px; overflow: hidden; }
  .bar-fill { height: 100%; border-radius: 4px; transition: width .4s; }
  .branch-count { font-size: 12px; color: #94a3b8; min-width: 30px; text-align: right; }

  /* Modal */
  .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 200; align-items: center; justify-content: center; padding: 20px; }
  .modal-overlay.open { display: flex; }
  .modal { background: white; border-radius: 14px; width: 780px; max-width: 100%; max-height: 90vh; display: flex; flex-direction: column; box-shadow: 0 24px 64px rgba(0,0,0,0.2); }
  .modal-header { padding: 18px 22px 14px; border-bottom: 1px solid #f1f5f9; display: flex; align-items: flex-start; justify-content: space-between; }
  .modal-title { font-size: 15px; font-weight: 600; }
  .modal-sub { font-size: 12px; color: #94a3b8; margin-top: 2px; }
  .modal-close { background: none; border: none; font-size: 22px; color: #94a3b8; cursor: pointer; line-height: 1; }
  .modal-close:hover { color: #1e293b; }
  .modal-body { flex: 1; overflow-y: auto; padding: 18px 22px; }
  .modal-footer { padding: 14px 22px; border-top: 1px solid #f1f5f9; display: flex; gap: 8px; justify-content: flex-end; }

  /* Equipo detail card */
  .detail-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 12px; margin-bottom: 16px; }
  .detail-item { background: #f8fafc; border-radius: 8px; padding: 10px 12px; }
  .detail-label { font-size: 11px; color: #94a3b8; margin-bottom: 3px; }
  .detail-value { font-size: 13px; font-weight: 500; color: #1e293b; word-break: break-all; }
  .detail-item.highlight { background: #ede9fe; }
  .detail-item.highlight .detail-value { color: #5b21b6; }

  /* Mantenimiento preventivo */
  .mant-card { background: white; border-radius: 10px; padding: 14px 16px; border: 0.5px solid rgba(0,0,0,0.07); }
  .mant-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
  .mant-equipo { font-size: 13px; font-weight: 600; color: #1e293b; }
  .mant-sucursal { font-size: 11px; color: #94a3b8; }
  .mant-fecha { font-size: 12px; }
  .mant-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px,1fr)); gap: 12px; }
  .mant-dias-badge { display: inline-block; font-size: 11px; font-weight: 600; padding: 2px 9px; border-radius: 20px; }
  .mant-vencido  { background: #fee2e2; color: #991b1b; }
  .mant-proximo  { background: #fef9c3; color: #854d0e; }
  .mant-ok       { background: #dcfce7; color: #166534; }
  .mant-sin-prog { background: #f1f5f9; color: #64748b; }
  .prog-bar-wrap { margin-top: 6px; }
  .prog-bar-track { height: 6px; background: #f1f5f9; border-radius: 4px; overflow: hidden; }
  .prog-bar-fill { height: 100%; border-radius: 4px; transition: width .4s; }

  /* Alertas */
  .alerta-item { display: flex; align-items: center; gap: 12px; background: white; border-radius: 8px; padding: 10px 14px; border: 0.5px solid rgba(0,0,0,.07); font-size: 13px; margin-bottom: 7px; }
  .alerta-item.red    { border-left: 3px solid #dc2626; }
  .alerta-item.yellow { border-left: 3px solid #d97706; }
  .alerta-item.blue   { border-left: 3px solid #6366f1; }
  .alerta-body { flex: 1; }
  .alerta-title { font-weight: 500; }
  .alerta-sub   { font-size: 12px; color: #94a3b8; margin-top: 1px; }
  .alerta-dias  { font-size: 11px; font-weight: 600; padding: 2px 8px; border-radius: 20px; flex-shrink: 0; }
  .alerta-dias.red    { background: #fee2e2; color: #991b1b; }
  .alerta-dias.yellow { background: #fef9c3; color: #854d0e; }
  .alerta-dias.blue   { background: #ede9fe; color: #5b21b6; }

  /* Timeline bitácora */
  .timeline { display: flex; flex-direction: column; gap: 0; }
  .tl-item { display: flex; gap: 12px; padding-bottom: 16px; position: relative; }
  .tl-item:not(:last-child)::before { content:''; position:absolute; left:15px; top:32px; bottom:0; width:2px; background:#f1f5f9; }
  .tl-dot { width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 13px; }
  .tl-dot.sistema { background: #ede9fe; }
  .tl-dot.usuario  { background: #dcfce7; }
  .tl-content { flex: 1; }
  .tl-meta { font-size: 11px; color: #94a3b8; margin-bottom: 4px; }
  .tl-text { font-size: 13px; color: #334155; background: #f8fafc; border-radius: 8px; padding: 8px 12px; line-height: 1.5; }
  .tl-text.sistema { background: #ede9fe; color: #3730a3; font-style: italic; }

  /* Period pills */
  .period-pills { display: flex; gap: 6px; }
  .period-pill { padding: 5px 14px; border-radius: 20px; border: 1px solid #e2e8f0; background: white; font-size: 12px; font-weight: 500; color: #64748b; cursor: pointer; transition: all .15s; }
  .period-pill:hover { border-color: #6366f1; color: #6366f1; }
  .period-pill.active { background: #6366f1; border-color: #6366f1; color: white; }

  /* Export btn */
  .btn-export { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; background: #f0fdf4; color: #16a34a; border: 1px solid #bbf7d0; border-radius: 6px; font-size: 12px; font-weight: 500; cursor: pointer; }
  .btn-export:hover { background: #dcfce7; }

  @keyframes pulse { 0%,100%{opacity:1}50%{opacity:.5} }
  .alert-pulse { animation: pulse 2s infinite; }
</style>
</head>
<body>

<div class="sidebar">
  <div class="sidebar-logo">🖥 Cómputo PRO</div>
  <div class="sidebar-sub">Control de equipos</div>
  <nav>
    <button class="active" onclick="mostrar('dashboard',this)"><span class="nav-icon">📊</span>Dashboard</button>
    <button onclick="mostrar('inventario',this)"><span class="nav-icon">🖥</span>Inventario</button>
    <button onclick="mostrar('incidencias',this)"><span class="nav-icon">🔧</span>Incidencias</button>
    <button onclick="mostrar('mantenimiento',this)"><span class="nav-icon">📅</span>Mantenimiento</button>
    <button onclick="mostrar('alertas',this)"><span class="nav-icon">🚨</span>Alertas <span class="sidebar-badge" id="sidebarBadge" style="display:none">0</span></button>
    <button onclick="mostrar('historico',this)"><span class="nav-icon">📋</span>Histórico</button>
    <button onclick="mostrar('reportes',this)"><span class="nav-icon">📈</span>Reportes</button>
    <button onclick="mostrar('config',this)"><span class="nav-icon">⚙️</span>Configuración</button>
  </nav>
</div>

<div class="main">

  <!-- ══ DASHBOARD ══ -->
  <div id="dashboard" class="section visible">
    <div class="page-header"><h2>Dashboard general</h2></div>
    <div class="metrics-grid">
      <div class="metric"><div class="metric-label">Total equipos</div><div class="metric-value info" id="dTotal">—</div><div class="metric-sub">en toda la red</div></div>
      <div class="metric"><div class="metric-label">Operativos</div><div class="metric-value ok" id="dOperativos">—</div><div class="metric-sub" id="dPctOp">—</div></div>
      <div class="metric"><div class="metric-label">Con falla</div><div class="metric-value fail" id="dFallas">—</div><div class="metric-sub" id="dPctFalla">—</div></div>
      <div class="metric"><div class="metric-label">Mantenimiento pendiente</div><div class="metric-value warn" id="dMant">—</div><div class="metric-sub">vencido o próximo</div></div>
    </div>

    <!-- Alertas widget -->
    <div id="dashAlertasWrap" style="display:none;margin-bottom:16px">
      <div class="card" style="border-left:3px solid #dc2626;padding:16px 20px">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
          <div style="font-size:14px;font-weight:600;display:flex;align-items:center;gap:8px">
            <span class="alert-pulse">🚨</span> Alertas activas
            <span class="badge badge-danger" id="dashAlertaTotal">0</span>
          </div>
          <button class="btn btn-sm btn-gray" onclick="mostrar('alertas',document.querySelector('.sidebar nav button:nth-child(5)'))">Ver todas</button>
        </div>
        <div id="dashAlertasList"></div>
      </div>
    </div>

    <div class="two-col">
      <div class="card">
        <div class="card-title">📊 Estado por tipo</div>
        <div style="position:relative;height:220px"><canvas id="graficaTipo"></canvas></div>
      </div>
      <div class="card">
        <div class="card-title">🏢 Equipos por sucursal</div>
        <div class="branch-list" id="branchBars"><div class="empty">Cargando…</div></div>
      </div>
    </div>

    <div class="card">
      <div class="card-title">🔧 Incidencias abiertas <span class="badge badge-danger" id="dIncAbiertas" style="font-size:11px">0</span></div>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Sucursal</th><th>Equipo</th><th>Colaborador</th><th>Técnico</th><th>Estado</th><th>Días abierto</th><th>Acciones</th></tr></thead>
          <tbody id="tablaIncDash"></tbody>
        </table>
        <div id="emptyIncDash" class="empty" style="display:none"><div class="e-icon">✅</div>Sin incidencias abiertas</div>
      </div>
    </div>
  </div>

  <!-- ══ INVENTARIO ══ -->
  <div id="inventario" class="section">
    <div class="page-header">
      <h2>Inventario de equipos</h2>
      <button class="btn btn-primary" onclick="abrirModalEquipo()">+ Agregar equipo</button>
    </div>
    <div class="filter-bar">
      <select id="filtInvSuc" onchange="renderInventario()">
        <option value="">Todas las sucursales</option>
        <option>Corporativo</option><option>Cedis</option><option>Hidalgo</option>
        <option>Construcasa</option><option>Ferrocarril</option><option>Simbolos</option>
        <option>Santa Rosa</option><option>Atzompa</option><option>Viguera</option>
        <option>Reforma</option><option>Tehuantepec</option><option>Puerto Escondido</option>
      </select>
      <select id="filtInvTipo" onchange="renderInventario()">
        <option value="">Todos los tipos</option>
        <option value="Desktop">Desktop</option>
        <option value="Laptop">Laptop</option>
      </select>
      <select id="filtInvEstado" onchange="renderInventario()">
        <option value="">Todos los estados</option>
        <option value="Activo">Activo</option>
        <option value="Falla">Falla</option>
        <option value="Mantenimiento">Mantenimiento</option>
        <option value="Baja">Baja</option>
      </select>
      <input type="text" id="filtInvBusqueda" placeholder="Buscar colaborador, marca, SN…" oninput="renderInventario()" style="min-width:200px">
      <div style="margin-left:auto;font-size:12px;color:#94a3b8" id="invContador"></div>
    </div>
    <div class="card" style="padding:0;overflow:hidden">
      <div class="table-wrap">
        <table>
          <thead><tr><th>Tipo</th><th>Sucursal</th><th>Colaborador</th><th>Marca / Modelo</th><th>S.O</th><th>IP</th><th>Estado</th><th>Próx. Mant.</th><th>Acciones</th></tr></thead>
          <tbody id="tablaInventario"></tbody>
        </table>
        <div id="emptyInv" class="empty" style="display:none"><div class="e-icon">🖥</div>No hay equipos registrados.</div>
      </div>
    </div>
  </div>

  <!-- ══ INCIDENCIAS ══ -->
  <div id="incidencias" class="section">
    <div class="page-header"><h2>Incidencias</h2></div>
    <div class="two-col" style="margin-bottom:16px">
      <!-- Registrar -->
      <div class="card">
        <div class="card-title">🔧 Registrar incidencia</div>
        <div class="form-group" style="margin-bottom:10px">
          <label>Sucursal</label>
          <select id="incSuc" onchange="cargarEquiposInc()">
            <option value="">Selecciona sucursal</option>
            <option>Corporativo</option><option>Cedis</option><option>Hidalgo</option>
            <option>Construcasa</option><option>Ferrocarril</option><option>Simbolos</option>
            <option>Santa Rosa</option><option>Atzompa</option><option>Viguera</option>
            <option>Reforma</option><option>Tehuantepec</option><option>Puerto Escondido</option>
          </select>
        </div>
        <div id="incEquipoStep" style="display:none">
          <div style="font-size:12px;color:#64748b;font-weight:500;margin-bottom:8px">Equipo con falla</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;max-height:200px;overflow-y:auto;margin-bottom:10px" id="incEquipoGrid"></div>
          <div id="incEquipoSelWrap" style="display:none;margin-bottom:10px">
            <div style="display:flex;align-items:center;gap:10px;background:#ede9fe;border-radius:8px;padding:8px 12px;font-size:13px;font-weight:500;color:#3730a3">
              <span id="incEquipoLabel">—</span>
              <button style="margin-left:auto;background:none;border:none;font-size:18px;cursor:pointer;color:#94a3b8" onclick="clearIncEquipo()">×</button>
            </div>
          </div>
          <div id="incRestoForm" style="display:none">
            <div class="form-group" style="margin-bottom:8px"><label>Técnico</label><input id="incTecnico" placeholder="Nombre del técnico"></div>
            <div class="form-group" style="margin-bottom:10px"><label>Descripción</label><textarea id="incDesc" rows="2" placeholder="Describe el problema…"></textarea></div>
            <button class="btn btn-primary" onclick="addInc()">Registrar incidencia</button>
          </div>
        </div>
        <input type="hidden" id="incEquipoId">
        <input type="hidden" id="incEquipoNombre">
        <input type="hidden" id="incColaborador">
      </div>
      <!-- Stats -->
      <div class="card">
        <div class="card-title">📊 Resumen incidencias</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px">
          <div class="metric" style="background:#f8fafc"><div class="metric-label">Abiertas</div><div class="metric-value fail" id="iStatAbiertas">0</div></div>
          <div class="metric" style="background:#f8fafc"><div class="metric-label">En proceso</div><div class="metric-value warn" id="iStatProceso">0</div></div>
