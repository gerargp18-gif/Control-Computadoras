function guardarMantenimiento() {
  const fecha = document.getElementById('mantFecha').value;
  const tec   = document.getElementById('mantTecnico').value.trim();
  const obs   = document.getElementById('mantObs').value.trim();
  if (!fecha||!tec) { toast('⚠ Completa fecha y técnico.'); return; }
  const ts = firebase.firestore.Timestamp.fromDate(new Date(fecha));
  db.collection('computos').doc(modalMantEquipoId).update({
    ultimoMant: ts, estado:'Activo'
  }).then(() => {
    db.collection('comp_mantenimientos').add({
      equipoId: modalMantEquipoId, fecha: ts, tecnico: tec, observaciones: obs,
      creadoEn: firebase.firestore.FieldValue.serverTimestamp()
    });
    toast('✅ Mantenimiento registrado.');
    document.getElementById('modalMant').classList.remove('open');
  }).catch(() => toast('Error.'));
}

function renderMantenimiento() {
  const fSuc = document.getElementById('filtMantSuc').value;
  const fStatus = document.getElementById('filtMantStatus').value;
  const hoy = new Date();
  let data = equiposCache.filter(e => {
    if (fSuc && e.sucursal!==fSuc) return false;
    if (e.estado==='Baja') return false;
    const freq = configCache[e.sucursal]||90;
    if (!e.ultimoMant) { return !fStatus || fStatus==='sin'; }
    const prox = new Date(e.ultimoMant.toDate().getTime()+freq*86400000);
    const diff = (prox-hoy)/86400000;
    if (fStatus==='vencido' && diff>0) return false;
    if (fStatus==='proximo' && (diff<=0||diff>DIAS_MANT_PROXIMO)) return false;
    if (fStatus==='ok' && diff<=DIAS_MANT_PROXIMO) return false;
    if (fStatus==='sin') return false;
    return true;
  });
  const grid = document.getElementById('mantGrid');
  if (!data.length) { grid.innerHTML='<div class="empty"><div class="e-icon">📅</div>Sin equipos con los filtros aplicados.</div>'; return; }
  grid.innerHTML = data.map(e => {
    const freq = configCache[e.sucursal]||90;
    let label='Sin programar', cls='mant-sin-prog', pct=0, proxStr='';
    if (e.ultimoMant) {
      const um = e.ultimoMant.toDate();
      const prox = new Date(um.getTime()+freq*86400000);
      const diff = Math.ceil((prox-hoy)/86400000);
      const elapsed = freq - diff;
      pct = Math.min(100,Math.max(0,Math.round(elapsed/freq*100)));
      proxStr = prox.toLocaleDateString('es-MX',{day:'2-digit',month:'short',year:'numeric'});
      if (diff<=0) { label=`Vencido ${Math.abs(diff)}d`; cls='mant-vencido'; }
      else if (diff<=DIAS_MANT_PROXIMO) { label=`En ${diff} días`; cls='mant-proximo'; }
      else { label=`En ${diff} días`; cls='mant-ok'; }
    }
    return `<div class="mant-card">
      <div class="mant-header">
        <div>
          <div class="mant-equipo">${chipEquipo(e.tipo)} ${e.marca} ${e.modelo||''}</div>
          <div class="mant-sucursal">${e.sucursal} · ${e.colaborador}</div>
        </div>
        <span class="mant-dias-badge ${cls}">${label}</span>
      </div>
      <div style="font-size:12px;color:#94a3b8;margin-bottom:6px">
        Último: ${e.ultimoMant?fmtFecha(e.ultimoMant):'—'} &nbsp;|&nbsp; Frecuencia: ${freq}d
        ${proxStr?`&nbsp;|&nbsp; Próximo: ${proxStr}`:''}
      </div>
      <div class="prog-bar-wrap">
        <div class="prog-bar-track">
          <div class="prog-bar-fill" style="width:${pct}%;background:${cls==='mant-vencido'?'#dc2626':cls==='mant-proximo'?'#d97706':'#16a34a'}"></div>
        </div>
      </div>
      <div style="margin-top:10px">
        <button class="btn btn-sm btn-primary" onclick="abrirModalMant('${e.id}')">Registrar mantenimiento</button>
      </div>
    </div>`;
  }).join('');
}

/* ── ALERTAS ── */
function renderAlertas() {
  const hoy = new Date();
  const rojas=[], amarillas=[], azules=[];

  incidenciasCache.filter(i=>i.estado!=='resuelta').forEach(i=>{
    if (diasDesde(i.fecha)>=DIAS_INC_ESTANCADA)
      rojas.push({title:`${i.equipo||'—'} · ${i.sucursal}`,sub:`Técnico: ${i.tecnico||'—'} · ${i.estado||'abierta'}`,label:`${Math.floor(diasDesde(i.fecha))}d sin mover`,id:i.id,eqNom:i.equipo||''});
  });

  equiposCache.forEach(e=>{
    const freq=configCache[e.sucursal]||90;
    if (!e.ultimoMant||e.estado==='Baja') {
      if (!e.ultimoMant) amarillas.push({title:`${e.marca} ${e.modelo||''} · ${e.sucursal}`,sub:`${e.colaborador} · Sin mantenimiento registrado`,label:'Sin programar'});
      return;
    }
    const prox=new Date(e.ultimoMant.toDate().getTime()+freq*86400000);
    const diff=(prox-hoy)/86400000;
    if (diff<=0) amarillas.push({title:`${e.marca} ${e.modelo||''} · ${e.sucursal}`,sub:`${e.colaborador} · Venció hace ${Math.abs(Math.ceil(diff))}d`,label:`Vencido ${Math.abs(Math.ceil(diff))}d`});
    else if (diff<=DIAS_MANT_PROXIMO) amarillas.push({title:`${e.marca} ${e.modelo||''} · ${e.sucursal}`,sub:`${e.colaborador} · Próximo en ${Math.ceil(diff)} días`,label:`En ${Math.ceil(diff)}d`});
  });

  const eqsConIncActiva = new Set(incidenciasCache.filter(i=>i.estado!=='resuelta').map(i=>i.equipoId));
  equiposCache.filter(e=>e.estado==='Falla'&&!eqsConIncActiva.has(e.id)).forEach(e=>{
    azules.push({title:`${e.marca} ${e.modelo||''} · ${e.sucursal}`,sub:`${e.colaborador} · Falla sin incidencia activa`,label:'Sin incidencia'});
  });

  const total=rojas.length+amarillas.length+azules.length;
  const badge=document.getElementById('sidebarBadge');
  badge.textContent=total; badge.style.display=total?'inline-flex':'none';
  document.getElementById('alertasTotalBadge').textContent=total;

  // Dashboard widget
  const dw=document.getElementById('dashAlertasWrap');
  if (total>0) {
    dw.style.display='block';
    document.getElementById('dashAlertaTotal').textContent=total;
    const tops=[...rojas.slice(0,2),...amarillas.slice(0,1),...azules.slice(0,1)];
    document.getElementById('dashAlertasList').innerHTML=tops.map(a=>{
      const c=rojas.includes(a)?'red':amarillas.includes(a)?'yellow':'blue';
      return `<div class="alerta-item ${c}"><div class="alerta-body"><div class="alerta-title">${a.title}</div><div class="alerta-sub">${a.sub}</div></div><span class="alerta-dias ${c}">${a.label}</span></div>`;
    }).join('')+(total>tops.length?`<div style="font-size:12px;color:#94a3b8;text-align:right;margin-top:6px">+${total-tops.length} más</div>`:'');
  } else dw.style.display='none';

  const panel=document.getElementById('alertasPanel');
  if (!total){panel.innerHTML='<div class="empty"><div class="e-icon">✅</div>Sin alertas activas.</div>';return;}
  let html='';
  if (rojas.length) html+=`<div style="font-size:12px;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px">🔴 Incidencias estancadas (+${DIAS_INC_ESTANCADA} días) <span class="badge badge-danger">${rojas.length}</span></div>${rojas.map(a=>`<div class="alerta-item red"><div class="alerta-body"><div class="alerta-title">${a.title}</div><div class="alerta-sub">${a.sub}</div></div><span class="alerta-dias red">${a.label}</span>${a.id?`<button class="btn btn-sm btn-gray" onclick="abrirBitacora('${a.id}','${(a.eqNom||'').replace(/'/g,"\\'")}','abierta')">📋</button>`:''}</div>`).join('')}<br>`;
  if (amarillas.length) html+=`<div style="font-size:12px;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px">🟡 Mantenimiento vencido o próximo <span class="badge badge-warn">${amarillas.length}</span></div>${amarillas.map(a=>`<div class="alerta-item yellow"><div class="alerta-body"><div class="alerta-title">${a.title}</div><div class="alerta-sub">${a.sub}</div></div><span class="alerta-dias yellow">${a.label}</span></div>`).join('')}<br>`;
  if (azules.length) html+=`<div style="font-size:12px;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px">🔵 Equipos en falla sin incidencia <span class="badge badge-info">${azules.length}</span></div>${azules.map(a=>`<div class="alerta-item blue"><div class="alerta-body"><div class="alerta-title">${a.title}</div><div class="alerta-sub">${a.sub}</div></div><span class="alerta-dias blue">${a.label}</span></div>`).join('')}`;
  panel.innerHTML=html;
}

/* ── BITÁCORA ── */
function abrirBitacora(incId, equipo, estado) {
  modalBitaIncId=incId;
  document.getElementById('bitaTitulo').textContent=`Bitácora — ${equipo}`;
  document.getElementById('bitaSubtitulo').textContent=estado;
  document.getElementById('bitaFooter').style.display=estado==='resuelta'?'none':'flex';
  document.getElementById('modalBitacora').classList.add('open');
  if (unsubBitacora) unsubBitacora();
  unsubBitacora=db.collection('comp_incidencias').doc(incId).collection('bitacora')
    .orderBy('fecha','asc').onSnapshot(snap=>{
      const items=snap.docs.map(d=>({id:d.id,...d.data()}));
      const cont=document.getElementById('bitaTimeline');
      if (!items.length){cont.innerHTML='<div class="empty">Sin comentarios.</div>';return;}
      cont.innerHTML=items.map(it=>{
        const es=it.tipo==='sistema';
        const f=it.fecha?it.fecha.toDate().toLocaleString('es-MX',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}):'—';
        return `<div class="tl-item"><div class="tl-dot ${es?'sistema':'usuario'}">${es?'⚙':'💬'}</div><div class="tl-content"><div class="tl-meta">${f}</div><div class="tl-text ${es?'sistema':''}">${it.texto}</div></div></div>`;
      }).join('');
      const mb=document.querySelector('.modal-body');
      setTimeout(()=>{if(mb)mb.scrollTop=mb.scrollHeight;},50);
    });
}
function cerrarModalBitacora(){
  document.getElementById('modalBitacora').classList.remove('open');
  if(unsubBitacora){unsubBitacora();unsubBitacora=null;}
  modalBitaIncId=null;
}
function guardarComentario(){
  const txt=document.getElementById('bitaComentario').value.trim();
  if(!txt||!modalBitaIncId){toast('⚠ Escribe un comentario.');return;}
  db.collection('comp_incidencias').doc(modalBitaIncId).collection('bitacora')
    .add({texto:txt,tipo:'usuario',fecha:firebase.firestore.FieldValue.serverTimestamp()})
    .then(()=>{document.getElementById('bitaComentario').value='';}).catch(()=>toast('Error.'));
}
document.getElementById('bitaComentario').addEventListener('keydown',e=>{if((e.ctrlKey||e.metaKey)&&e.key==='Enter')guardarComentario();});
document.getElementById('modalBitacora').addEventListener('click',e=>{if(e.target===document.getElementById('modalBitacora'))cerrarModalBitacora();});

/* ── HISTÓRICO ── */
function renderHistorico(){
  const fSuc=document.getElementById('filtHistSuc').value;
  const fDes=document.getElementById('filtHistDesde').value;
  const fHas=document.getElementById('filtHistHasta').value;
  const fBus=document.getElementById('filtHistBus').value.toLowerCase();
  const desde=fDes?new Date(fDes+'T00:00:00'):null;
  const hasta=fHas?new Date(fHas+'T23:59:59'):null;
  const data=incidenciasCache.filter(i=>{
    if((i.estado||'abierta')!=='resuelta')return false;
    if(fSuc&&i.sucursal!==fSuc)return false;
    if(i.fechaCierre){const fc=i.fechaCierre.toDate();if(desde&&fc<desde)return false;if(hasta&&fc>hasta)return false;}
    if(fBus&&![(i.equipo||''),(i.colaborador||''),(i.tecnico||''),(i.descripcion||'')].join(' ').toLowerCase().includes(fBus))return false;
    return true;
  }).sort((a,b)=>{const da=a.fechaCierre?a.fechaCierre.toDate():new Date(0),db2=b.fechaCierre?b.fechaCierre.toDate():new Date(0);return db2-da;});
  const tbody=document.getElementById('tablaHist'),empty=document.getElementById('emptyHist');
  if(!data.length){tbody.innerHTML='';empty.style.display='block';return;}
  empty.style.display='none';
  tbody.innerHTML=data.map((i,idx)=>`<tr>
    <td style="color:#94a3b8">${idx+1}</td><td>${fmtFecha(i.fecha)}</td><td>${fmtFecha(i.fechaCierre)}</td>
    <td><strong>${i.equipo||'—'}</strong></td><td>${i.sucursal||'—'}</td><td>${i.colaborador||'—'}</td><td>${i.tecnico||'—'}</td>
    <td style="font-weight:500;color:#16a34a">${calcTiempo(i.fecha,i.fechaCierre)||'—'}</td>
    <td style="color:#64748b;max-width:180px">${i.descripcion||'—'}</td>
    <td><button class="btn btn-sm btn-gray" onclick="abrirBitacora('${i.id}','${(i.equipo||'').replace(/'/g,"\\'")}','resuelta')">📋</button></td>
  </tr>`).join('');
}
function exportarHistCSV(){
  const data=incidenciasCache.filter(i=>(i.estado||'abierta')==='resuelta');
  if(!data.length){toast('Sin datos.');return;}
  const h=['FechaApertura','FechaCierre','Equipo','Sucursal','Colaborador','Tecnico','TiempoResolucion','Descripcion'];
  const rows=data.map(i=>{const esc=v=>`"${String(v||'').replace(/"/g,'""')}"`;return[fmtFecha(i.fecha),fmtFecha(i.fechaCierre),i.equipo,i.sucursal,i.colaborador,i.tecnico,calcTiempo(i.fecha,i.fechaCierre)||'—',i.descripcion].map(esc).join(',');});
  const csv=[h.join(','),...rows].join('\n');
  const a=document.createElement('a');a.href=URL.createObjectURL(new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8;'}));
  a.download=`historico_computos_${new Date().toISOString().slice(0,10)}.csv`;a.click();toast('✓ CSV descargado.');
}

/* ── REPORTES ── */
function setRepPeriodo(p,btn){
  repPeriodo=p;
  document.querySelectorAll('.period-pill').forEach(el=>el.classList.remove('active'));
  btn.classList.add('active');
  const cr=document.getElementById('repCustomRange');
  cr.style.display=p==='custom'?'flex':'none';
  if(p!=='custom')renderReportes();
}
function getRepRango(){
  const ahora=new Date();let desde,hasta;
  if(repPeriodo==='custom'){const d=document.getElementById('repDesde').value,h=document.getElementById('repHasta').value;return{desde:d?new Date(d+'T00:00:00'):null,hasta:h?new Date(h+'T23:59:59'):null};}
  hasta=new Date(ahora);hasta.setHours(23,59,59,999);
  if(repPeriodo==='dia'){desde=new Date(ahora);desde.setHours(0,0,0,0);}
  else if(repPeriodo==='semana'){desde=new Date(ahora);desde.setDate(desde.getDate()-desde.getDay());desde.setHours(0,0,0,0);}
  else{desde=new Date(ahora.getFullYear(),ahora.getMonth(),1,0,0,0,0);}
  return{desde,hasta};
}
function renderReportes(){
  const{desde,hasta}=getRepRango();
  const data=incidenciasCache.filter(i=>{
    if(!i.fecha)return false;const d=i.fecha.toDate();
    if(desde&&d<desde)return false;if(hasta&&d>hasta)return false;return true;
  });
  document.getElementById('rTotal').textContent=data.length;
  document.getElementById('rEquipos').textContent=new Set(data.map(i=>i.equipoId)).size;
  document.getElementById('rTecnicos').textContent=new Set(data.map(i=>i.tecnico).filter(Boolean)).size;
  const tiempos=data.filter(i=>i.estado==='resuelta'&&i.fecha&&i.fechaCierre).map(i=>i.fechaCierre.toDate()-i.fecha.toDate()).filter(m=>m>0);
  document.getElementById('rMTTR').textContent=tiempos.length?msToLabel(tiempos.reduce((a,b)=>a+b,0)/tiempos.length):'—';
  // Chart
  const agr={};data.forEach(i=>{const k=i.fecha.toDate().toISOString().slice(0,10);agr[k]=(agr[k]||0)+1;});
  const labels=desde&&hasta?[...Array(Math.ceil((hasta-desde)/86400000))].map((_,i)=>new Date(desde.getTime()+i*86400000).toISOString().slice(0,10)):Object.keys(agr).sort();
  const valores=labels.map(d=>agr[d]||0);
  if(chartRep)chartRep.destroy();
  chartRep=new Chart(document.getElementById('graficaRep'),{type:'bar',data:{labels,datasets:[{data:valores,backgroundColor:'rgba(99,102,241,0.75)',borderRadius:4,borderSkipped:false}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{display:false},ticks:{font:{size:10}}},y:{beginAtZero:true,ticks:{stepSize:1,font:{size:10}},grid:{color:'#f1f5f9'}}}}});
  // Branch bars
  const porSuc={};data.forEach(i=>{const s=i.sucursal||'—';porSuc[s]=(porSuc[s]||0)+1;});
  const maxS=Math.max(...Object.values(porSuc),1);
  document.getElementById('repBranchBars').innerHTML=Object.entries(porSuc).sort((a,b)=>b[1]-a[1]).slice(0,8).map(([n,c])=>`<div class="branch-row"><div class="branch-name">${n}</div><div class="bar-track"><div class="bar-fill" style="width:${Math.round(c/maxS*100)}%;background:#6366f1"></div></div><div class="branch-count">${c}</div></div>`).join('')||'<div class="empty">Sin datos.</div>';
  // Tabla
  const tbody=document.getElementById('tablaRep'),empty=document.getElementById('emptyRep');
  if(!data.length){tbody.innerHTML='';empty.style.display='block';return;}
  empty.style.display='none';
  tbody.innerHTML=[...data].sort((a,b)=>b.fecha.toDate()-a.fecha.toDate()).map((i,idx)=>`<tr>
    <td style="color:#94a3b8">${idx+1}</td><td>${fmtFecha(i.fecha)}</td><td><strong>${i.equipo||'—'}</strong></td>
    <td>${i.sucursal||'—'}</td><td>${i.tecnico||'—'}</td><td>${chipInc(i.estado||'abierta')}</td>
    <td style="font-size:12px">${calcTiempo(i.fecha,i.fechaCierre)||'—'}</td>
    <td style="color:#64748b;font-size:12px">${i.descripcion||'—'}</td>
  </tr>`).join('');
}
function exportarRepCSV(){
  const{desde,hasta}=getRepRango();
  const data=incidenciasCache.filter(i=>{if(!i.fecha)return false;const d=i.fecha.toDate();if(desde&&d<desde)return false;if(hasta&&d>hasta)return false;return true;});
  if(!data.length){toast('Sin datos.');return;}
  const h=['Fecha','Equipo','Sucursal','Colaborador','Tecnico','Estado','TiempoResolucion','Descripcion'];
  const rows=data.map(i=>{const esc=v=>`"${String(v||'').replace(/"/g,'""')}"`;return[fmtFecha(i.fecha),i.equipo,i.sucursal,i.colaborador,i.tecnico,i.estado||'abierta',calcTiempo(i.fecha,i.fechaCierre)||'—',i.descripcion].map(esc).join(',');});
  const csv=[h.join(','),...rows].join('\n');
  const a=document.createElement('a');a.href=URL.createObjectURL(new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8;'}));
  a.download=`reporte_computos_${new Date().toISOString().slice(0,10)}.csv`;a.click();toast('✓ CSV descargado.');
}

/* ── CONFIGURACIÓN ── */
function renderConfig(){
  const cont=document.getElementById('configSucursales');
  cont.innerHTML=SUCURSALES.map(s=>`
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px">
      <div style="width:140px;font-size:13px;color:#334155;font-weight:500">${s}</div>
      <input type="number" id="cfg_${s.replace(/ /g,'_')}" value="${configCache[s]||90}" min="7" max="365" style="width:80px;padding:5px 8px;border-radius:6px;border:1px solid #e2e8f0;font-size:13px">
      <span style="font-size:12px;color:#94a3b8">días</span>
    </div>`).join('');
}
function guardarConfig(){
  const batch=db.batch();
  SUCURSALES.forEach(s=>{
    const el=document.getElementById('cfg_'+s.replace(/ /g,'_'));
    if(el){const v=parseInt(el.value);if(v>0){configCache[s]=v;batch.set(db.collection('comp_config').doc(s),{dias:v});}}
  });
  batch.commit().then(()=>toast('✅ Configuración guardada.')).catch(()=>toast('Error.'));
}

