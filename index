    estado: document.getElementById('eqEstado').value,
    monitor: document.getElementById('eqMonitor').value.trim(),
    monitorSN: document.getElementById('eqMonitorSN').value.trim(),
    teclado: document.getElementById('eqTeclado').value.trim(),
    tecladoSN: document.getElementById('eqTecladoSN').value.trim(),
