function avanzarEstado(id, estadoActual, equipoId) {
  const sig = estadoActual==='abierta'?'en proceso':'resuelta';
  const upd = {estado:sig};
  if (sig==='resuelta') {
    upd.fechaCierre = firebase.firestore.FieldValue.serverTimestamp();
    if (equipoId) db.collection('computos').doc(equipoId).update({estado:'Activo'});
  }
  db.collection('comp_incidencias').doc(id).update(upd).then(() => {
    db.collection('comp_incidencias').doc(id).collection('bitacora').add({
      texto: sig==='resuelta'?'✅ Incidencia resuelta. Equipo marcado como Activo.':'🔧 Incidencia iniciada / en proceso.',
      tipo:'sistema', fecha:firebase.firestore.FieldValue.serverTimestamp()
    });
    toast(sig==='resuelta'?'✅ Resuelta. Equipo activo.':'🔧 En proceso.');
  }).catch(() => toast('Error.'));
}
function btnAvanzar(id, estado, eqId) {
  if (estado==='resuelta') return '—';
  const label = estado==='abierta'?'Iniciar':'Resolver';
  const cls   = estado==='abierta'?'btn-amber':'btn-success';
  return `<button class="btn btn-sm ${cls}" onclick="avanzarEstado('${id}','${estado}','${eqId||''}')">${label}</button>`;
}

/* ── RENDERS ── */
function renderDashboard() {
  const total = equiposCache.length;
  const fallas = equiposCache.filter(e=>e.estado==='Falla').length;
  const op = equiposCache.filter(e=>e.estado==='Activo').length;
  document.getElementById('dTotal').textContent = total;
  document.getElementById('dOperativos').textContent = op;
  document.getElementById('dFallas').textContent = fallas;
  document.getElementById('dPctOp').textContent = total?`${Math.round(op/total*100)}% del total`:'';
  document.getElementById('dPctFalla').textContent = total?`${Math.round(fallas/total*100)}% del total`:'';

  // Mantenimiento pendiente
  const hoy = new Date();
  let mantPend = 0;
  equiposCache.forEach(e => {
    const freq = configCache[e.sucursal] || 90;
    if (!e.ultimoMant) { mantPend++; return; }
    const prox = new Date(e.ultimoMant.toDate().getTime() + freq*86400000);
    const diff = (prox - hoy)/86400000;
    if (diff <= DIAS_MANT_PROXIMO) mantPend++;
  });
  document.getElementById('dMant').textContent = mantPend;

  // Chart tipo
  const laptops = equiposCache.filter(e=>e.tipo==='Laptop').length;
  const desktops = equiposCache.filter(e=>e.tipo==='Desktop').length;
  if (chartTipo) chartTipo.destroy();
  chartTipo = new Chart(document.getElementById('graficaTipo'), {
    type:'doughnut',
    data:{labels:['Desktop','Laptop','Falla','Mant.'],datasets:[{data:[desktops-equiposCache.filter(e=>e.tipo==='Desktop'&&e.estado==='Falla').length,laptops-equiposCache.filter(e=>e.tipo==='Laptop'&&e.estado==='Falla').length,fallas,equiposCache.filter(e=>e.estado==='Mantenimiento').length],backgroundColor:['#6366f1','#8b5cf6','#dc2626','#d97706'],borderWidth:2,borderColor:'#fff'}]},
    options:{responsive:true,maintainAspectRatio:false,cutout:'60%',plugins:{legend:{position:'bottom',labels:{font:{size:11}}}}}
  });

  // Branch bars
  const porSuc = {};
  equiposCache.forEach(e=>{ if(!porSuc[e.sucursal])porSuc[e.sucursal]={total:0,falla:0}; porSuc[e.sucursal].total++; if(e.estado==='Falla')porSuc[e.sucursal].falla++; });
  const maxT = Math.max(...Object.values(porSuc).map(v=>v.total),1);
  document.getElementById('branchBars').innerHTML = Object.entries(porSuc).sort((a,b)=>b[1].total-a[1].total).map(([n,v])=>`
    <div class="branch-row">
      <div class="branch-name">${n}</div>
      <div class="bar-track"><div class="bar-fill" style="width:${Math.round(v.total/maxT*100)}%;background:#6366f1"></div></div>
      <div class="branch-count">${v.total}</div>
    </div>`).join('') || '<div class="empty">Sin datos.</div>';

  // Inc abiertas
  const abiertas = incidenciasCache.filter(i=>i.estado!=='resuelta');
  document.getElementById('dIncAbiertas').textContent = abiertas.length;
  const tbodyD = document.getElementById('tablaIncDash');
  const emptyD = document.getElementById('emptyIncDash');
  if (!abiertas.length) { tbodyD.innerHTML=''; emptyD.style.display='block'; }
  else {
    emptyD.style.display='none';
    tbodyD.innerHTML = abiertas.sort((a,b)=>{ const da=a.fecha?a.fecha.toDate():new Date(0),db2=b.fecha?b.fecha.toDate():new Date(0); return db2-da; }).map(i=>`<tr>
      <td>${i.sucursal||'—'}</td><td><strong>${i.equipo||'—'}</strong></td><td>${i.colaborador||'—'}</td><td>${i.tecnico||'—'}</td>
      <td>${chipInc(i.estado||'abierta')}</td>
      <td style="color:${diasDesde(i.fecha)>=DIAS_INC_ESTANCADA?'#dc2626':'#64748b'}">${Math.floor(diasDesde(i.fecha))}d</td>
      <td style="display:flex;gap:5px">${btnAvanzar(i.id,i.estado||'abierta',i.equipoId)}<button class="btn btn-sm btn-gray" onclick="abrirBitacora('${i.id}','${(i.equipo||'').replace(/'/g,"\\'")}','${i.estado||'abierta'}')">📋</button></td>
    </tr>`).join('');
  }
}

