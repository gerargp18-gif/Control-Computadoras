function fmtFecha(ts) {
  if (!ts) return '—';
  return ts.toDate ? ts.toDate().toLocaleDateString('es-MX',{day:'2-digit',month:'2-digit',year:'numeric'}) : '—';
}
function fmtHora(ts) {
  if (!ts) return '—';
  return ts.toDate ? ts.toDate().toLocaleTimeString('es-MX',{hour:'2-digit',minute:'2-digit'}) : '—';
}
function diasDesde(ts) {
  if (!ts) return 9999;
  return (Date.now() - ts.toDate().getTime()) / 86400000;
}
function calcTiempo(f, fc) {
  if (!f || !fc) return null;
  const ms = fc.toDate() - f.toDate();
  if (ms < 0) return null;
  const m = Math.floor(ms/60000);
  if (m < 60) return `${m}m`;
  const h = Math.floor(m/60), rm = m%60;
  if (h < 24) return rm ? `${h}h ${rm}m` : `${h}h`;
  const d = Math.floor(h/24), rh = h%24;
  return rh ? `${d}d ${rh}h` : `${d}d`;
}
function msToLabel(ms) {
  const m = Math.floor(ms/60000);
  if (m < 60) return `${m}m`;
  const h = Math.floor(m/60), rm = m%60;
  if (h < 24) return rm ? `${h}h ${rm}m` : `${h}h`;
  const d = Math.floor(h/24), rh = h%24;
  return rh ? `${d}d ${rh}h` : `${d}d`;
}
function chipInc(estado) {
  const m = {abierta:'chip-falla','en proceso':'chip-mant',resuelta:'chip-activo'};
  return `<span class="chip ${m[estado]||'chip-falla'}">${estado}</span>`;
