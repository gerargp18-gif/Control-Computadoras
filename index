  equiposCache=snap.docs.map(d=>({id:d.id,...d.data()}));
  renderDashboard();
  renderInventario();
  if(document.getElementById('mantenimiento').classList.contains('visible'))renderMantenimiento();
  renderAlertas();
});
db.collection('comp_incidencias').onSnapshot(snap=>{
  incidenciasCache=snap.docs.map(d=>({id:d.id,...d.data()}));
  renderDashboard();
  renderTablaInc();
  renderIncStats();
  renderAlertas();
  if(document.getElementById('historico').classList.contains('visible'))renderHistorico();
  if(document.getElementById('reportes').classList.contains('visible'))renderReportes();
});
db.collection('comp_config').onSnapshot(snap=>{
  snap.docs.forEach(d=>{configCache[d.id]=d.data().dias;});
});
